.vscode/

# Docs — ignore large binaries and personal notes; track architecture diagrams
docs/*.pdf
docs/*.docx
docs/*.md
docs/*.py
docs/figures/*.png
docs/figures/*.pdf
docs/figures/*.tex
docs/_build_tikz.sh
# Whitelist the canonical-results doc the README points reviewers to.
!docs/experiment-log.md

# Paper — track sources (manuscript.tex, references.bib, build.sh, README,
# checklist), PNG figures, and table .tex. Ignore LaTeX build artifacts, the
# heavy binaries (docx + compiled pdf), the figure PDF masters, and the archive.
paper/archive/
paper/manuscript.docx
paper/*.pdf
paper/figures/*.pdf
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz

# Windows / WSL download cruft
*:Zone.Identifier
